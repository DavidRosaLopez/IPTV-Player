{
  "name": "iptv-player",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "check": "node scripts/check-js.mjs",
    "dev:desktop": "electron .",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "hls.js": "^1.5.15"
  },
  "build": {
    "appId": "com.drosalop.iptvplayer",
    "productName": "IPTV Player",
    "asar": true,
    "files": [
      "index.html",
      "css/**/*",
      "img/**/*",
      "js/**/*",
      "scripts/**/*",
      "desktop/**/*",
      "web-remote/**/*",
      "config.xml",
      "tizen_web_project.yaml",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
